{
  "name": "react-native-accessibility-scanner",
  "version": "1.0.0",
  "description": "Accessibility auditing for React Native apps — CLI, ESLint plugin, GitHub Action, and programmatic API.",
  "keywords": [
    "react-native",
    "accessibility",
    "a11y",
    "eslint",
    "scanner",
    "linting",
    "audit"
  ],
  "author": "Your Name",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "react-native-accessibility-scan": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./eslint": "./dist/eslint/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/react-native-accessibility-scanner"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/react-native-accessibility-scanner/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/react-native-accessibility-scanner#readme"
}
